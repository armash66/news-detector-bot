# TruthLens API Configuration

# Environment
DEBUG=True
DATABASE_URL=postgresql://user:pass@localhost:5432/truthlens
SECRET_KEY=generate_a_secure_random_hex_string_in_production

# AI Engine
OCR_ENABLED=True
MODEL_LAYER_MODE=sparse # set to 'dense' for production CLIP/ResNet loading

# OSINT Feeds
CRAWL_INTERVAL_SECONDS=60
MAX_FEED_AGE_HOURS=24
