# API Keys for Evidence Retrieval
NEWS_API_KEY=your_newsapi_key_here
SERP_API_KEY=your_serpapi_key_here

# Model Configuration
MODEL_NAME=roberta-base
MAX_SEQ_LENGTH=512
BATCH_SIZE=16
LEARNING_RATE=2e-5
NUM_EPOCHS=3

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Paths
MODEL_CHECKPOINT_DIR=./checkpoints
DATA_DIR=./data
CACHE_DIR=./cache
