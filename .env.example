# TruthLens v3 Environment Variables
# Copy to .env and fill in values

# ── Database ──────────────────────────────
POSTGRES_USER=truthlens_user
POSTGRES_PASSWORD=truthlens_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=truthlens
USE_SQLITE=true

# ── Redis ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Neo4j ─────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=truthlens_password

# ── NLP ───────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm

# ── App ───────────────────────────────────
DEBUG=false
API_RATE_LIMIT=100
